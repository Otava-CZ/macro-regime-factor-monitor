@page "/"
@inject FactorScoringService ScoringService

<PageTitle>Macro Dashboard</PageTitle>

<h1>Dashboard</h1>
<p class="lede">Latest persisted factor scores and pressure-aware macro interpretations from the SQLite database.</p>

@if (snapshot is null)
{
    <p>Loading scores...</p>
}
else if (snapshot.FactorScores.Count == 0)
{
    <section class="card">No factor scores are available yet.</section>
}
else
{
    <section class="summary-grid">
        <div class="metric-card">
            <span>As of</span>
            <strong>@snapshot.AsOfDate.ToString("yyyy-MM-dd")</strong>
        </div>
        <div class="metric-card">
            <span>Regime</span>
            <strong>@snapshot.Regime</strong>
        </div>
        <div class="metric-card">
            <span>Composite score</span>
            <strong>@snapshot.CompositeScore</strong>
        </div>
    </section>

    <section class="card">
        <h2>Factor Scores</h2>
        <table>
            <thead>
                <tr>
                    <th>Factor</th>
                    <th>Category</th>
                    <th class="number">Raw</th>
                    <th class="number">Weighted</th>
                    <th>Risk-asset impact</th>
                    <th>Macro pressure reading</th>
                    <th>Notes</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var score in snapshot.FactorScores)
                {
                    <tr>
                        <td>@score.MacroFactor?.Name</td>
                        <td>@score.MacroFactor?.Category</td>
                        <td class="number">@score.RawScore</td>
                        <td class="number">@score.WeightedScore</td>
                        <td><span class="pill">@score.RegimeImpact</span></td>
                        <td>@DescribePressure(score)</td>
                        <td>@score.Notes</td>
                    </tr>
                }
            </tbody>
        </table>
    </section>

    <section class="card">
        <h2>Macro Pressure Interpretations</h2>
        <p class="section-note">Factor scores are normalized for risk-asset support. These interpretations remap each scored factor into explicit macro pressure polarity.</p>
        @if (snapshot.PressureInterpretations.Count == 0)
        {
            <p>No pressure interpretations are available for the scored factors.</p>
        }
        else
        {
            <div class="pressure-list">
                @foreach (var interpretation in snapshot.PressureInterpretations)
                {
                    <article>
                        <div>
                            <strong>@interpretation.PressureName</strong>
                            <span class="pill">@interpretation.Stance</span>
                        </div>
                        <p>@interpretation.Summary</p>
                        <p><strong>Contributing scored factors:</strong> @(string.Join(", ", interpretation.ContributingFactors))</p>
                    </article>
                }
            </div>
        }
    </section>

    <section class="card">
        <h2>Category Signals</h2>
        <div class="category-list">
            @foreach (var category in snapshot.CategoryScores)
            {
                <div>
                    <span>@category.Category</span>
                    <strong>@category.Score</strong>
                </div>
            }
        </div>
    </section>
}

@code {
    private DashboardSnapshot? snapshot;

    private static string DescribePressure(FactorScore score)
    {
        var name = score.MacroFactor?.Name;
        if (string.IsNullOrWhiteSpace(name))
        {
            return "No mapped pressure polarity.";
        }

        var pressureContribution = name.Equals("Market Complacency", StringComparison.OrdinalIgnoreCase)
            ? score.WeightedScore
            : -score.WeightedScore;

        var direction = pressureContribution switch
        {
            >= 0.25m => "adds macro pressure",
            <= -0.25m => "eases macro pressure",
            _ => "is macro-pressure neutral"
        };

        return $"{name} {direction} ({pressureContribution}).";
    }

    protected override async Task OnInitializedAsync()
    {
        snapshot = await ScoringService.GetLatestSnapshotAsync();
    }
}
