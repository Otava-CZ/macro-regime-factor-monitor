@page "/"
@inject FactorScoringService ScoringService

<PageTitle>Macro Dashboard</PageTitle>

<h1>Dashboard</h1>
<p class="lede">Latest persisted macro factor scores from the SQLite database.</p>

@if (snapshot is null)
{
    <p>Loading scores...</p>
}
else if (snapshot.FactorScores.Count == 0)
{
    <section class="card">No factor scores are available yet.</section>
}
else
{
    <section class="summary-grid">
        <div class="metric-card">
            <span>As of</span>
            <strong>@snapshot.AsOfDate.ToString("yyyy-MM-dd")</strong>
        </div>
        <div class="metric-card">
            <span>Regime</span>
            <strong>@snapshot.Regime</strong>
        </div>
        <div class="metric-card">
            <span>Composite score</span>
            <strong>@snapshot.CompositeScore</strong>
        </div>
    </section>

    <section class="card">
        <h2>Measurable Factor Scores</h2>
        <p class="section-note">Raw and weighted scores retain each factor's scoring direction. The impact column translates those scores into macro pressure or relief wording for the monitor.</p>
        <table>
            <thead>
                <tr>
                    <th>Factor</th>
                    <th>Category</th>
                    <th class="number">Raw</th>
                    <th class="number">Weighted</th>
                    <th class="number">Pressure</th>
                    <th>Impact</th>
                    <th>Interpretation</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var contribution in snapshot.FactorContributions)
                {
                    var score = contribution.FactorScore;
                    <tr>
                        <td>@score.MacroFactor?.Name</td>
                        <td>@score.MacroFactor?.Category</td>
                        <td class="number">@score.RawScore</td>
                        <td class="number">@score.WeightedScore</td>
                        <td class="number">@contribution.PressureScore</td>
                        <td><span class="pill">@contribution.Reading</span></td>
                        <td>@contribution.Explanation</td>
                    </tr>
                }
            </tbody>
        </table>
    </section>

    <section class="card">
        <h2>Macro Pressure Interpretations</h2>
        <p class="section-note">Derived interpretations group the six measurable factors into four pressure readings without turning the monitor into a fixed scenario classifier.</p>
        <div class="interpretation-list">
            @foreach (var interpretation in snapshot.Interpretations)
            {
                <article>
                    <div class="interpretation-header">
                        <div>
                            <h3>@interpretation.Name</h3>
                            <p>@interpretation.Explanation</p>
                        </div>
                        <div class="interpretation-score">
                            <span>Score</span>
                            <strong>@interpretation.Score</strong>
                            <span class="pill">@interpretation.Reading</span>
                        </div>
                    </div>
                    <p class="contributor-label">Contributing measurable factors</p>
                    <ul>
                        @foreach (var contributor in interpretation.Contributors)
                        {
                            <li>@contributor.FactorScore.MacroFactor?.Name (@contributor.Reading, @contributor.PressureScore)</li>
                        }
                    </ul>
                </article>
            }
        </div>
    </section>

    <section class="card">
        <h2>Category Signals</h2>
        <div class="category-list">
            @foreach (var category in snapshot.CategoryScores)
            {
                <div>
                    <span>@category.Category</span>
                    <strong>@category.Score</strong>
                </div>
            }
        </div>
    </section>
}

@code {
    private DashboardSnapshot? snapshot;

    protected override async Task OnInitializedAsync()
    {
        snapshot = await ScoringService.GetLatestSnapshotAsync();
    }
}
