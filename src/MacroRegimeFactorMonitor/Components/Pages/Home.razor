@page "/"
@inject FactorScoringService ScoringService

<PageTitle>Macro Dashboard</PageTitle>

<h1>Dashboard</h1>
<p class="lede">Raw data flows into six measurable factor scores, then into explicit macro interpretations, then into manual trade candidates.</p>

@if (snapshot is null)
{
    <p>Loading scores...</p>
}
else if (snapshot.FactorScores.Count == 0)
{
    <section class="card">No factor scores are available yet.</section>
}
else
{
    <section class="message @DataModeBannerCss">
        <strong>@DataModeBannerText</strong>
        <div>Latest ScoreDate: @snapshot.AsOfDate.ToString("yyyy-MM-dd")</div>
        <div>DataMode: @snapshot.DataMode</div>
        @if (!string.IsNullOrWhiteSpace(snapshot.ScoringModelVersion))
        {
            <div>ScoringModelVersion: @snapshot.ScoringModelVersion</div>
        }
    </section>

    <section class="summary-grid">
        <div class="metric-card">
            <span>As of</span>
            <strong>@snapshot.AsOfDate.ToString("yyyy-MM-dd")</strong>
        </div>
        <div class="metric-card">
            <span>Primary macro interpretation</span>
            <strong>@snapshot.PrimaryMacroInterpretation</strong>
        </div>
        <div class="metric-card">
            <span>Composite score</span>
            <strong>@snapshot.CompositeScore</strong>
        </div>
        <div class="metric-card">
            <span>Composite regime label</span>
            <strong>@snapshot.CompositeRegimeLabel</strong>
        </div>
    </section>


    <section class="card">
        <h2>Derived Macro Interpretations</h2>
        <p class="section-note">Interpretations are derived from the six measurable factors; they do not replace the factor monitor or create automatic trading decisions.</p>
        <div class="interpretation-grid">
            @foreach (var interpretation in snapshot.MacroInterpretations)
            {
                <article>
                    <span>@interpretation.Name</span>
                    <strong>@interpretation.Reading</strong>
                    <p>Score: @interpretation.Score</p>
                    <p><strong>Contributors:</strong> @interpretation.SupportingFactors</p>
                    <p><strong>Pressure contribution:</strong> @interpretation.FactorContributions</p>
                    <p class="why"><strong>Why this interpretation?</strong> @interpretation.Explanation</p>
                </article>
            }
        </div>
    </section>

    <section class="card">
        <h2>Factor Scores</h2>
        <div class="table-scroll">
        <table>
            <thead>
                <tr>
                    <th>Factor</th>
                    <th>Category</th>
                    <th class="number">Raw</th>
                    <th class="number">Weighted</th>
                    <th class="number">Pressure contribution</th>
                    <th>Impact</th>
                    <th>DataQualityStatus</th>
                    <th>SourceObservationDate</th>
                    <th class="number">DaysSinceSourceObservation</th>
                    <th>Interpretation note</th>
                    <th>Notes</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var score in snapshot.FactorScores)
                {
                    var pressureContribution = FactorScoreCalculator.CalculatePressureContribution(score);

                    <tr>
                        <td>@score.MacroFactor?.Name</td>
                        <td>@score.MacroFactor?.Category</td>
                        <td class="number">@score.RawScore</td>
                        <td class="number">@score.WeightedScore</td>
                        <td class="number">@pressureContribution</td>
                        <td><span class="pill">@FactorScoreCalculator.ClassifyPressureImpact(pressureContribution, score.MacroFactor?.Name)</span></td>
                        <td><span class="pill @DataQualityStatusCss(score.DataQualityStatus)">@FormatNullableText(score.DataQualityStatus)</span></td>
                        <td>@FormatNullableDate(score.SourceObservationDate)</td>
                        <td class="number">@FormatNullableInt(score.DaysSinceSourceObservation)</td>
                        <td>@FactorScoreCalculator.ExplainPressureImpact(pressureContribution, score.MacroFactor?.Name)</td>
                        <td>@score.Notes</td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
    </section>

    <section class="card">
        <h2>Category Signals</h2>
        <div class="category-list">
            @foreach (var category in snapshot.CategoryScores)
            {
                <div>
                    <span>@category.Category</span>
                    <strong>@category.Score</strong>
                </div>
            }
        </div>
    </section>
}

@code {
    private DashboardSnapshot? snapshot;

    private string DataModeBannerText
    {
        get
        {
            if (snapshot is null)
            {
                return string.Empty;
            }

            var modes = snapshot.FactorScores
                .Select(score => score.DataMode)
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .ToList();

            if (modes.Count == 1 && string.Equals(modes[0], "Sample", StringComparison.OrdinalIgnoreCase))
            {
                return "Dashboard is showing sample/seed scores. Imported observations are not currently driving this view.";
            }

            if (modes.Count == 1 && string.Equals(modes[0], ImportedObservationScoringService.ImportedManualDataMode, StringComparison.OrdinalIgnoreCase))
            {
                return "Dashboard is showing manually calculated scores from imported observations.";
            }

            return "Dashboard is showing mixed score data modes. Interpret carefully.";
        }
    }

    private string DataModeBannerCss
    {
        get
        {
            if (snapshot is null)
            {
                return "warning";
            }

            var modeCount = snapshot.FactorScores
                .Select(score => score.DataMode)
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .Count();

            return modeCount == 1 ? "warning" : "error";
        }
    }

    protected override async Task OnInitializedAsync()
    {
        snapshot = await ScoringService.GetLatestSnapshotAsync();
    }

    private static string FormatNullableDate(DateOnly? date) => date?.ToString("yyyy-MM-dd") ?? "—";

    private static string FormatNullableInt(int? value) => value?.ToString() ?? "—";

    private static string FormatNullableText(string? value) => string.IsNullOrWhiteSpace(value) ? "—" : value!;

    private static string DataQualityStatusCss(string? status) => status switch
    {
        "Fresh" => "pill-success",
        "Stale" => "pill-warning",
        "Missing" => "pill-error",
        "Placeholder" => "pill-muted",
        _ => "pill-muted"
    };
}
