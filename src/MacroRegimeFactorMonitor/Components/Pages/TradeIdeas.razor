@page "/trade-ideas"
@inject JournalService JournalService

<PageTitle>Trade Ideas</PageTitle>

<h1>Trade Idea Journal</h1>
<p class="lede">Log discretionary ideas for review. The app intentionally has no broker integration or automatic trading.</p>

<section class="card">
    <h2>New idea</h2>
    <EditForm Model="draft" OnValidSubmit="SaveAsync" FormName="trade-idea-form">
        <DataAnnotationsValidator />
        <div class="form-grid">
            <label>
                Idea date
                <InputDate @bind-Value="draft.IdeaDate" />
            </label>
            <label>
                Title
                <InputText @bind-Value="draft.Title" />
            </label>
            <label>
                Instrument
                <InputText @bind-Value="draft.Instrument" />
            </label>
            <label>
                Status
                <InputSelect @bind-Value="draft.Status">
                    <option>Watching</option>
                    <option>Active</option>
                    <option>Closed</option>
                </InputSelect>
            </label>
            <label class="wide">
                Thesis
                <InputTextArea @bind-Value="draft.Thesis" />
            </label>
            <label class="wide">
                Entry trigger
                <InputTextArea @bind-Value="draft.EntryTrigger" />
            </label>
            <label class="wide">
                Invalidation
                <InputTextArea @bind-Value="draft.Invalidation" />
            </label>
            <label class="wide">
                Catalyst
                <InputTextArea @bind-Value="draft.Catalyst" />
            </label>
            <label>
                Max loss
                <InputNumber @bind-Value="draft.MaxLoss" />
            </label>
            <label>
                Time horizon
                <InputText @bind-Value="draft.TimeHorizon" />
            </label>
            <label class="wide">
                Risk notes
                <InputTextArea @bind-Value="draft.RiskNotes" />
            </label>
            <label class="wide">
                Post-mortem
                <InputTextArea @bind-Value="draft.PostMortem" />
            </label>
        </div>
        <button type="submit">Save idea</button>
    </EditForm>
</section>

<section class="card">
    <h2>Saved ideas</h2>
    @if (ideas is null)
    {
        <p>Loading ideas...</p>
    }
    else
    {
        @foreach (var idea in ideas)
        {
            <article class="journal-entry">
                <div>
                    <strong>@idea.Title</strong>
                    <span class="pill">@idea.Status</span>
                </div>
                <p>@idea.IdeaDate.ToString("yyyy-MM-dd") · @idea.Instrument</p>
                <p>@idea.Thesis</p>
                <dl class="idea-details">
                    <div>
                        <dt>Entry trigger</dt>
                        <dd>@Display(idea.EntryTrigger)</dd>
                    </div>
                    <div>
                        <dt>Invalidation</dt>
                        <dd>@Display(idea.Invalidation)</dd>
                    </div>
                    <div>
                        <dt>Catalyst</dt>
                        <dd>@Display(idea.Catalyst)</dd>
                    </div>
                    <div>
                        <dt>Max loss</dt>
                        <dd>@DisplayCurrency(idea.MaxLoss)</dd>
                    </div>
                    <div>
                        <dt>Time horizon</dt>
                        <dd>@Display(idea.TimeHorizon)</dd>
                    </div>
                    <div>
                        <dt>Risk notes</dt>
                        <dd>@Display(idea.RiskNotes)</dd>
                    </div>
                    <div>
                        <dt>Post-mortem</dt>
                        <dd>@Display(idea.PostMortem)</dd>
                    </div>
                </dl>
            </article>
        }
    }
</section>

@code {
    private TradeIdea draft = NewDraft();
    private List<TradeIdea>? ideas;

    protected override async Task OnInitializedAsync()
    {
        ideas = await JournalService.GetTradeIdeasAsync();
    }

    private async Task SaveAsync()
    {
        await JournalService.AddTradeIdeaAsync(draft);
        draft = NewDraft();
        ideas = await JournalService.GetTradeIdeasAsync();
    }

    private static TradeIdea NewDraft() => new()
    {
        IdeaDate = DateOnly.FromDateTime(DateTime.UtcNow.Date),
        Title = string.Empty,
        Status = "Watching"
    };

    private static string Display(string value) => string.IsNullOrWhiteSpace(value) ? "—" : value;

    private static string DisplayCurrency(decimal? value) => value.HasValue ? value.Value.ToString("C0") : "—";
}
