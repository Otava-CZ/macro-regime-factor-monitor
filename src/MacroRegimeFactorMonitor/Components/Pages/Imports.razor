@page "/imports"
@inject ImportAdminService ImportAdminService

<PageTitle>Data Imports</PageTitle>

<h1>Data Imports</h1>
<p class="lede">Run controlled, manual imports for existing external series mappings. Fetched observations are persisted to IndicatorObservations, while dashboard scoring remains unchanged.</p>

<section class="card">
    <div class="section-heading">
        <div>
            <h2>ExternalSeries mappings</h2>
            <p class="section-note">Active mappings are shown by default. Use the date fields to limit a manual import window. Existing observations are skipped unless force refresh is selected.</p>
        </div>
        <label class="checkbox-label">
            <InputCheckbox @bind-Value="includeInactive" @bind-Value:after="LoadExternalSeriesAsync" disabled="@IsBusy" />
            Show inactive
        </label>
    </div>

    <div class="action-row">
        <button type="button" disabled="@IsBusy" @onclick="RefreshAllActiveFredSeriesAsync">
            @(isBatchRunning ? "Refreshing active FRED series..." : "Refresh all active FRED series")
        </button>
        <span class="section-note">Manual only. Uses overlap windows and ForceRefresh to catch revised FRED observations.</span>
    </div>

    @if (externalSeries is null)
    {
        <p>Loading external series...</p>
    }
    else if (externalSeries.Count == 0)
    {
        <p>No external series mappings are available.</p>
    }
    else
    {
        <div class="table-scroll">
            <table>
                <thead>
                    <tr>
                        <th>Id</th>
                        <th>Data source</th>
                        <th>Indicator</th>
                        <th>External series</th>
                        <th>Frequency</th>
                        <th>Freshness</th>
                        <th>Latest observation</th>
                        <th>Days since latest</th>
                        <th>Units</th>
                        <th>Transform</th>
                        <th>Active</th>
                        <th>Last successful import UTC</th>
                        <th>Manual import</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var series in externalSeries)
                    {
                        <tr>
                            <td>@series.Id</td>
                            <td>@series.DataSourceName</td>
                            <td>@series.IndicatorName</td>
                            <td><code>@series.ExternalSeriesId</code></td>
                            <td>@series.Frequency</td>
                            <td><span class="pill @FreshnessCssClass(series.FreshnessStatus)">@series.FreshnessStatus</span></td>
                            <td>@FormatDate(series.LatestObservationDate)</td>
                            <td>@FormatDays(series.DaysSinceLatestObservation)</td>
                            <td>@series.Units</td>
                            <td><code>@series.Transform</code></td>
                            <td>@(series.IsActive ? "Yes" : "No")</td>
                            <td>@FormatDateTime(series.LastSuccessfulImportUtc)</td>
                            <td>
                                @if (series.IsActive)
                                {
                                    <div class="inline-import-form">
                                        <label>
                                            From
                                            <InputDate TValue="DateOnly?" @bind-Value="series.FromDate" disabled="@IsBusy" />
                                        </label>
                                        <label>
                                            To
                                            <InputDate TValue="DateOnly?" @bind-Value="series.ToDate" disabled="@IsBusy" />
                                        </label>
                                        <label class="checkbox-label">
                                            <InputCheckbox @bind-Value="series.ForceRefresh" disabled="@IsBusy" />
                                            Force refresh existing observations
                                        </label>
                                        <button type="button" disabled="@IsBusy" @onclick="() => RunImportAsync(series)">
                                            @(isImportRunning ? "Import running..." : "Run import")
                                        </button>
                                    </div>
                                }
                                else
                                {
                                    <span class="section-note">Inactive</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>

@if (latestBatchResult is not null)
{
    <section class="card result-card">
        <h2>Latest refresh-all result</h2>
        <div class="summary-grid">
            <div class="metric-card"><span>Status</span><strong>@latestBatchResult.Status</strong></div>
            <div class="metric-card"><span>Series attempted</span><strong>@latestBatchResult.SeriesAttempted</strong></div>
            <div class="metric-card"><span>Series completed</span><strong>@latestBatchResult.SeriesCompleted</strong></div>
            <div class="metric-card"><span>Series failed</span><strong>@latestBatchResult.SeriesFailed</strong></div>
            <div class="metric-card"><span>Total rows read</span><strong>@latestBatchResult.TotalRowsRead</strong></div>
            <div class="metric-card"><span>Total rows inserted</span><strong>@latestBatchResult.TotalRowsInserted</strong></div>
            <div class="metric-card"><span>Total rows updated</span><strong>@latestBatchResult.TotalRowsUpdated</strong></div>
            <div class="metric-card"><span>Total rows skipped</span><strong>@latestBatchResult.TotalRowsSkipped</strong></div>
        </div>

        <div class="table-scroll">
            <table>
                <thead>
                    <tr>
                        <th>External series</th>
                        <th>Window</th>
                        <th>Status</th>
                        <th class="number">Read</th>
                        <th class="number">Inserted</th>
                        <th class="number">Updated</th>
                        <th class="number">Skipped</th>
                        <th>Error</th>
                        <th>Warnings</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var result in latestBatchResult.SeriesResults)
                    {
                        <tr>
                            <td><code>@result.ExternalSeriesCode</code></td>
                            <td>@FormatDate(result.FromDate) to @FormatDate(result.ToDate)</td>
                            <td><span class="pill">@result.Status</span></td>
                            <td class="number">@result.RowsRead</td>
                            <td class="number">@result.RowsInserted</td>
                            <td class="number">@result.RowsUpdated</td>
                            <td class="number">@result.RowsSkipped</td>
                            <td>@result.ErrorMessage</td>
                            <td>@string.Join(" ", result.Warnings)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
}

@if (latestResult is not null)
{
    <section class="card result-card">
        <h2>Latest manual import result</h2>
        <div class="summary-grid">
            <div class="metric-card">
                <span>Status</span>
                <strong>@latestResult.Status</strong>
            </div>
            <div class="metric-card">
                <span>Rows read</span>
                <strong>@latestResult.RowsRead</strong>
            </div>
            <div class="metric-card">
                <span>Rows inserted</span>
                <strong>@latestResult.RowsInserted</strong>
            </div>
            <div class="metric-card">
                <span>Rows updated</span>
                <strong>@latestResult.RowsUpdated</strong>
            </div>
            <div class="metric-card">
                <span>Rows skipped</span>
                <strong>@latestResult.RowsSkipped</strong>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(latestResult.ErrorMessage))
        {
            <p class="message error"><strong>Error:</strong> @latestResult.ErrorMessage</p>
        }

        @if (latestResult.Warnings.Count > 0)
        {
            <div class="message warning">
                <strong>Warnings</strong>
                <ul>
                    @foreach (var warning in latestResult.Warnings)
                    {
                        <li>@warning</li>
                    }
                </ul>
            </div>
        }
    </section>
}

<section class="card">
    <div class="section-heading">
        <div>
            <h2>Imported observations</h2>
            <p class="section-note">Recent persisted observations, newest first. Read-only view limited to 50 rows.</p>
        </div>
        <label>
            ExternalSeries
            <InputSelect @bind-Value="selectedObservationExternalSeriesId" @bind-Value:after="LoadRecentObservationsAsync" disabled="@IsBusy">
                <option value="">All series</option>
                @if (externalSeries is not null)
                {
                    @foreach (var series in externalSeries)
                    {
                        <option value="@series.Id">@series.ExternalSeriesId</option>
                    }
                }
            </InputSelect>
        </label>
    </div>

    @if (recentObservations is null)
    {
        <p>Loading observations...</p>
    }
    else if (recentObservations.Count == 0)
    {
        <p>No imported observations match the current filter.</p>
    }
    else
    {
        <div class="table-scroll">
            <table>
                <thead>
                    <tr>
                        <th>ObservationDate</th>
                        <th>Indicator.Name</th>
                        <th>ExternalSeries.ExternalSeriesId</th>
                        <th class="number">Value</th>
                        <th>Source</th>
                        <th>DataImportRunId</th>
                        <th>CreatedAtUtc</th>
                        <th>UpdatedAtUtc</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var observation in recentObservations)
                    {
                        <tr>
                            <td>@FormatDate(observation.ObservationDate)</td>
                            <td>@observation.IndicatorName</td>
                            <td><code>@observation.ExternalSeriesCode</code></td>
                            <td class="number">@observation.Value</td>
                            <td>@observation.Source</td>
                            <td>@FormatNullableInt(observation.DataImportRunId)</td>
                            <td>@FormatDateTime(observation.CreatedAtUtc)</td>
                            <td>@FormatDateTime(observation.UpdatedAtUtc)</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>

<section class="card">
    <h2>Latest DataImportRuns</h2>
    @if (recentRuns is null)
    {
        <p>Loading import runs...</p>
    }
    else if (recentRuns.Count == 0)
    {
        <p>No import runs have been recorded yet.</p>
    }
    else
    {
        <div class="table-scroll">
            <table>
                <thead>
                    <tr>
                        <th>Started UTC</th>
                        <th>Finished UTC</th>
                        <th>Data source</th>
                        <th>Status</th>
                        <th class="number">Rows read</th>
                        <th class="number">Rows inserted</th>
                        <th class="number">Rows updated</th>
                        <th>Error</th>
                        <th>Notes</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var run in recentRuns)
                    {
                        <tr>
                            <td>@FormatDateTime(run.StartedAtUtc)</td>
                            <td>@FormatDateTime(run.FinishedAtUtc)</td>
                            <td>@run.DataSourceName</td>
                            <td><span class="pill">@run.Status</span></td>
                            <td class="number">@run.RowsRead</td>
                            <td class="number">@run.RowsInserted</td>
                            <td class="number">@run.RowsUpdated</td>
                            <td>@run.ErrorMessage</td>
                            <td>@run.Notes</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>

@code {
    private bool includeInactive;
    private bool isImportRunning;
    private bool isBatchRunning;
    private int? selectedObservationExternalSeriesId;
    private List<ExternalSeriesAdminRow>? externalSeries;
    private List<DataImportRunAdminRow>? recentRuns;
    private List<ImportedObservationAdminRow>? recentObservations;
    private ImportSeriesResult? latestResult;
    private ImportBatchResult? latestBatchResult;

    private bool IsBusy => isImportRunning || isBatchRunning;

    protected override async Task OnInitializedAsync()
    {
        await LoadPageDataAsync();
    }

    private async Task LoadPageDataAsync()
    {
        await LoadExternalSeriesAsync();
        await LoadRecentObservationsAsync();
        await LoadRecentRunsAsync();
    }

    private async Task LoadExternalSeriesAsync()
    {
        externalSeries = await ImportAdminService.GetExternalSeriesAsync(includeInactive);
    }

    private async Task LoadRecentRunsAsync()
    {
        recentRuns = await ImportAdminService.GetRecentImportRunsAsync();
    }

    private async Task LoadRecentObservationsAsync()
    {
        recentObservations = await ImportAdminService.GetRecentObservationsAsync(selectedObservationExternalSeriesId);
    }

    private async Task RunImportAsync(ExternalSeriesAdminRow series)
    {
        isImportRunning = true;
        latestBatchResult = null;
        try
        {
            latestResult = await ImportAdminService.RunImportAsync(new ImportSeriesRequest
            {
                ExternalSeriesId = series.Id,
                FromDate = series.FromDate,
                ToDate = series.ToDate,
                ForceRefresh = series.ForceRefresh
            });

            await LoadPageDataAsync();
        }
        finally
        {
            isImportRunning = false;
        }
    }

    private async Task RefreshAllActiveFredSeriesAsync()
    {
        isBatchRunning = true;
        latestResult = null;
        try
        {
            latestBatchResult = await ImportAdminService.RefreshAllActiveFredSeriesAsync();
            await LoadPageDataAsync();
        }
        finally
        {
            isBatchRunning = false;
        }
    }

    private static string FormatDateTime(DateTime? value) =>
        value.HasValue ? value.Value.ToString("yyyy-MM-dd HH:mm:ss") : "—";

    private static string FormatDate(DateOnly? value) =>
        value.HasValue ? FormatDate(value.Value) : "—";

    private static string FormatDate(DateOnly value) => value.ToString("yyyy-MM-dd");

    private static string FormatDays(int? value) => value.HasValue ? value.Value.ToString() : "—";

    private static string FormatNullableInt(int? value) => value.HasValue ? value.Value.ToString() : "—";

    private static string FreshnessCssClass(string status) => status switch
    {
        FreshnessStatus.Fresh => "pill-success",
        FreshnessStatus.Stale => "pill-warning",
        FreshnessStatus.Missing => "pill-muted",
        _ => string.Empty
    };
}
